{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AnnotationIR",
  "type": "object",
  "required": ["id", "source", "body", "target", "metadata"],
  "properties": {
    "id": { "type": "string" },
    "source": {
      "type": "object",
      "required": ["format", "filePath", "adapter"],
      "properties": {
        "format": { "enum": ["markdown", "docx", "pdf", "wps", "web"] },
        "filePath": { "type": "string" },
        "adapter": { "type": "string" }
      }
    },
    "body": {
      "type": "object",
      "required": ["text", "kind"],
      "properties": {
        "text": { "type": "string" },
        "kind": { "enum": ["comment", "revision", "highlight", "inline-note", "question"] },
        "type": { "enum": ["style", "structure", "continuity", "fact", "rhythm", "tone", "other"] },
        "priority": { "enum": ["low", "medium", "high"] }
      }
    },
    "target": {
      "type": "object",
      "properties": {
        "file": { "type": "string" },
        "chapterId": { "type": "string" },
        "blockId": { "type": "string" },
        "selectedText": { "type": "string" },
        "prefix": { "type": "string" },
        "suffix": { "type": "string" },
        "startOffset": { "type": "integer" },
        "endOffset": { "type": "integer" },
        "beforeHash": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "author": { "type": "string" },
        "createdAt": { "type": "string" },
        "modifiedAt": { "type": "string" },
        "status": { "enum": ["open", "in_review", "patched", "accepted", "rejected", "converted_to_rule", "resolved", "ignored", "needs_remap"] }
      }
    }
  }
}
